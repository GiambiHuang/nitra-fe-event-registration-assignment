{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "compilerOptions": {
    "paths": {
      "src/*": ["./src/*"]
    },
    "types": ["node"],
    "allowJs": true,
    "checkJs": false,
    "noEmit": true
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts", "src/**/*.vue", "*.config.js", "*.config.ts"],
  "exclude": ["node_modules", "dist", ".quasar"]
}
